<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_light"
    android:padding="24dp">

    <ImageView
        android:id="@+id/kn_ze_iv_profile"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@android:drawable/sym_def_app_icon"
        android:layout_marginTop="64dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/kn_ze_tv_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Khatia Nozadze"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/primary_green"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/kn_ze_iv_profile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/kn_ze_tv_bio"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Android Developer Student"
        android:textAlignment="center"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/kn_ze_tv_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <View
        android:id="@+id/kn_ze_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/kn_ze_tv_bio"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Wealth Tracker v1.0"
        android:textSize="12sp"
        android:textColor="#BDBDBD"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>