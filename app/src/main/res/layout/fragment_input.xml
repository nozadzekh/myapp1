<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light_green"
    android:padding="24dp">

    <TextView
        android:id="@+id/kn_ze_tv_input_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Financial Input"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/primary_green"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="32dp"/>

    <TextView
        android:id="@+id/kn_ze_tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Track your income and expenses"
        android:textColor="@color/text_secondary"
        app:layout_constraintTop_toBottomOf="@id/kn_ze_tv_input_title"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="24dp"/>

    <EditText
        android:id="@+id/kn_ze_et_income"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Monthly Income"
        android:inputType="numberDecimal"
        android:background="@drawable/kn_ze_bg_edittext"
        android:padding="16dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/kn_ze_tv_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/kn_ze_et_expense"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Monthly Expenses"
        android:inputType="numberDecimal"
        android:background="@drawable/kn_ze_bg_edittext"
        android:padding="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/kn_ze_et_income"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/kn_ze_btn_save"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="Calculate Savings"
        android:backgroundTint="@color/primary_green"
        android:textColor="@color/white"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/kn_ze_et_expense"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:cornerRadius="12dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>